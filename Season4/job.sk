			{스킬::음식::%player%::소식형인간} >= 5
			{스킬::음식::%player%::강철위장} >= 1
			{스킬::음식::%player%::플라시보} < 5
			add 1 to {스킬::음식::%player%::플라시보}
			remove 1 from {스킬::%player%::포인트}
			set slot 13 of {GUI::음식직업GUI::%player%} to glass bottle named "{@스킬네임}플라시보" with lore "{@스킬로어}내가 방금 마신게 포션이었나? 물이었나?" , "{@스킬로어}물병 섭취시 레벨*20%% 확률로 랜덤한 상태이상에 걸립니다.", "{@스킬제한}소식형 인간 Lv.5 이상, 강철 위장 Lv.1 이상", "&8클릭시 레벨업합니다.", " " and "{@스킬로어}레벨: &f%{스킬::음식::%player%::플라시보}% / 5"
		if {_slot} is 15:
