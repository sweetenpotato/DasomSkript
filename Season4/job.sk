			remove 1 from {스킬::%player%::포인트}
			set slot 25 of {GUI::음식직업GUI::%player%} to cod named "{@스킬네임}자린고비" with lore "{@스킬로어}밥 한숟갈에 굴비 한 번만 보라고 했지!", "{@스킬로어}음식을 소모할 확률이 레벨*5%% 줄어듭니다.", "{@스킬제한} 뉴턴의 법칙 Lv.2 이상", "&8클릭시 레벨업합니다.", " " and "{@스킬로어}레벨: &f%{스킬::음식::%{_p}%::자린고비}% / 10"

			
		
on inventory close:
	if {GUI::스킬변환GUI::*} contains player's current inventory:
		delete {GUI::스킬변환GUI::%player%::*}
		wait 1 tick
		{GUI::스킬변환GUI::*} does not contain player's current inventory
		delete {스킬투자::%player%}
	if {GUI::체력직업GUI::*} contains player's current inventory:
		delete {GUI::체력직업GUI::%player%::*}
	if {GUI::음식직업GUI::*} contains player's current inventory:
		delete {GUI::음식직업GUI::%player%::*}
		







		
on inventory click:
	if {GUI::직업GUI::*} contains player's current inventory:
		cancel event
		set {_slot} to clicked slot
		if {_slot} is 0:
			send component {GUI::직업GUI::광부} to player
			close player's inventory
		if {_slot} is 1:
			send component {GUI::직업GUI::농부} to player
			close player's inventory
		if {_slot} is 2:
			send component {GUI::직업GUI::목수} to player
			close player's inventory
		if {_slot} is 3:
			send component {GUI::직업GUI::사냥꾼} to player
			close player's inventory
		if {_slot} is 4:
			send component {GUI::직업GUI::어부} to player
			close player's inventory
